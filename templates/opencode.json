{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama-cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "{env:OLLAMA_API_KEY}"
      },
      "models": {
        "minimax-m3:cloud":             { "name": "MiniMax M3 (vision/multimodal)" },
        "glm-5.2":                      { "name": "GLM 5.2 (heavy coding)" },
        "deepseek-v4-flash":            { "name": "DeepSeek V4 Flash (fast)" },
        "gemma3:12b":                   { "name": "Gemma 3 12B (lite)" },
        "devstral-small-2:24b":         { "name": "Devstral Small 2 24B (test gen)" },
        "gpt-oss:20b":                  { "name": "GPT-OSS 20B (docs)" },
        "kimi-k2.6":                    { "name": "Kimi K2.6 (planning/research)" },
        "kimi-k2.7-code":               { "name": "Kimi K2.7 Code (implementation)" },
        "minimax-m2.7":                 { "name": "MiniMax M2.7 (review)" },
        "devstral-2:123b-cloud":        { "name": "Devstral 2 123B (heavy coding)" },
        "deepseek-v4-pro:cloud":        { "name": "DeepSeek V4 Pro (deep research)" },
        "gemini-3-flash-preview:cloud": { "name": "Gemini 3 Flash (orchestration)" },
        "gpt-oss:120b-cloud":           { "name": "GPT-OSS 120B (heavy docs)" }
      }
    }
  },
  "model": "ollama-cloud/glm-5.2",
  "small_model": "ollama-cloud/deepseek-v4-flash",
  "default_agent": "commander",
  "plugin": [
    "@ramtinj95/opencode-tokenscope",
    "opencode-synced",
    "opencode-queue",
    "@tarquinen/opencode-dcp",
    "opencode-mem",
    "./plugin/clause-cache.ts",
    "./plugin/clause-rag.ts",
    "./plugin/clause-compact.ts"
  ]
}
